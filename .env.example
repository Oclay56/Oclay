STAKE_BASE_URL=https://odds-data.stake.com
STAKE_TIMEOUT_SECONDS=20
STAKE_CACHE_TTL_SECONDS=20
MLB_STATS_BASE_URL=https://statsapi.mlb.com/api/v1
MLB_STATS_TIMEOUT_SECONDS=20
APP_TIMEZONE=America/New_York
AZP_DB_PATH=data/gpt_action.sqlite
AZP_MIN_PLAYABLE_ODDS=1.10
# Local UI-job queue (the bridge between the API and the Stake helper). It is a
# local WAL-mode SQLite file -- no external service. Finished rows are auto-pruned
# so it stays tiny.
OCLAY_LOCAL_UI_JOB_DB=data/local_ui_jobs.sqlite
# Seconds a finished (completed/failed/expired) job row is kept before pruning.
OCLAY_LOCAL_UI_JOB_RETENTION_SECONDS=1800
# How often (minutes) the helper prunes the job queue + Chrome rebuildable caches.
OCLAY_AUTO_CLEANUP_MINUTES=60
AZP_CHROME_PATH=
AZP_STAKE_CHROME_PROFILE=data\chrome-stake-ui
# Your free, permanent ngrok static domain (e.g. oclay-yourname.ngrok-free.app).
# Set this and the tunnel uses a URL that never changes -- paste it into the GPT
# Action once and never copy-paste again. Leave blank to use a temporary tunnel.
OCLAY_NGROK_DOMAIN=
# Show the background API + tunnel windows that start with the TUI.
# false (default): they run completely hidden -- no window, no taskbar entry,
#   visible only in Task Manager. You only see the main TUI window.
# true: they open as visible (minimized) windows, handy for debugging/logs.
SHOW_BACKGROUND_TERMINALS=false

# Seconds to wait between each per-fixture SGM board read in a batch. Stake
# rate-limits the replay endpoint, so spacing the reads avoids tripping a
# 429 / IP-block. Raise it (e.g. 1.0-1.5) if you still get rate-limited;
# lower it toward 0 only on a single-game scan. Default: 0.6.
OCLAY_SGM_BOARD_THROTTLE_SECONDS=0.6

# Avenue 2 (line-shopping vs a sharp book). Point this at a JSON file holding the
# sharp no-vig lines snapshot; the candidate pool flags any Stake price that
# beats it. The file is keyed "player|market|line" -> {over, under, book,
# capturedAt}, and is refreshed by your sharp-odds feed (or POST /oclay/sharp-lines).
# Leave unset to disable line-shopping (the signal simply never fires).
OCLAY_SHARP_LINES_PATH=data/sharp_lines.json
# Set to 1 to force line-shopping off even if a path is configured.
OCLAY_DISABLE_SHARP_LINES=

# The Odds API feed (the-odds-api.com) -- fills the sharp-lines snapshot above.
# Get a key (free tier = 500 requests/month). `sharp-refresh` lists events (free)
# then pulls each game's props, billed per market per game, so a full slate of
# the 5 default batter markets costs ~75 credits. Cap games with --max-events.
OCLAY_ODDS_API_KEY=
# Reference book. Pinnacle does NOT carry MLB player props on The Odds API, so
# the default is a multi-book no-vig "consensus" (median across the US books that
# price each prop). Set to a single book key (e.g. betmgm) to use just that book.
OCLAY_ODDS_API_BOOKMAKER=consensus
# Comma-separated Odds API market keys to pull. Default: batter_hits,
# batter_total_bases,batter_home_runs,batter_hits_runs_rbis,batter_rbis.
OCLAY_ODDS_API_MARKETS=
