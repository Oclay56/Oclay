# Core
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Example dedicated RPCs:
# - Helius mainnet: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# - Helius Gatekeeper (beta): https://beta.helius-rpc.com/?api-key=YOUR_KEY
# Solana RPC rate limits (tune to avoid 429s)
RPC_CONCURRENCY=2
RPC_INTERVAL_CAP=8
RPC_INTERVAL_MS=1000
DB_PATH=data/oclay.sqlite
CONFIG_PATH=config/default.json
LOG_LEVEL=info
MAX_CONCURRENCY=6
KILL_SWITCH=false
# Dashboard logging (used when --dashboard is enabled)
DASHBOARD_LOG_LEVEL=warn
DASHBOARD_LOG_TARGET=stderr
# Used only when DASHBOARD_LOG_TARGET=file
DASHBOARD_LOG_PATH=

# Trading wallet (required for live trading; optional for paper mode unless you use tx simulation)
WALLET_KEYPAIR_PATH=C:\\path\\to\\solana-keypair.json

# Live trading safety rails (default is OFF)
LIVE_TRADING=false
# Must equal: I_UNDERSTAND_THIS_CAN_LOSE_MONEY
LIVE_TRADING_CONFIRM=

# Jupiter Ultra (default uses the public lite API; set JUP_API_KEY only if using api.jup.ag)
JUP_BASE_URL=https://lite-api.jup.ag/ultra/v1
JUP_API_KEY=

# DexScreener
DEXSCREENER_BASE_URL=https://api.dexscreener.com

# Real-time stream discovery (Helius WS)
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Optional Raydium API base (used only if direct metadata fallback is needed)
RAYDIUM_API_BASE_URL=

# Telemetry override (optional; config.telemetry.enabled is source of truth when unset)
TELEMETRY_ENABLED=true

# Optional proxy (Node fetch honors standard env vars via undici; PowerShell users may also set this)
HTTP_PROXY=
HTTPS_PROXY=
