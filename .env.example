STAKE_BASE_URL=https://odds-data.stake.com
STAKE_TIMEOUT_SECONDS=20
STAKE_CACHE_TTL_SECONDS=20
MLB_STATS_BASE_URL=https://statsapi.mlb.com/api/v1
MLB_STATS_TIMEOUT_SECONDS=20
APP_TIMEZONE=America/New_York
AZP_DB_PATH=data/gpt_action.sqlite
AZP_MIN_PLAYABLE_ODDS=1.10
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
AZP_LOCAL_UI_JOB_TABLE=local_ui_jobs
AZP_SUPABASE_JOB_RETENTION_HOURS=6
AZP_SUPABASE_STALE_JOB_MINUTES=15
AZP_SUPABASE_AUTO_CLEANUP_MINUTES=60
AZP_CHROME_PATH=
AZP_STAKE_CHROME_PROFILE=data\chrome-stake-ui
# Your free, permanent ngrok static domain (e.g. oclay-yourname.ngrok-free.app).
# Set this and the tunnel uses a URL that never changes -- paste it into the GPT
# Action once and never copy-paste again. Leave blank to use a temporary tunnel.
OCLAY_NGROK_DOMAIN=
# Show the background API + tunnel windows that start with the TUI.
# false (default): they run completely hidden -- no window, no taskbar entry,
#   visible only in Task Manager. You only see the main TUI window.
# true: they open as visible (minimized) windows, handy for debugging/logs.
SHOW_BACKGROUND_TERMINALS=false

# Seconds to wait between each per-fixture SGM board read in a batch. Stake
# rate-limits the replay endpoint, so spacing the reads avoids tripping a
# 429 / IP-block. Raise it (e.g. 1.0-1.5) if you still get rate-limited;
# lower it toward 0 only on a single-game scan. Default: 0.6.
OCLAY_SGM_BOARD_THROTTLE_SECONDS=0.6
